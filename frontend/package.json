{
  "name": "fcpricemaster-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "tsc -b && vite build",
    "build:electron": "tsc -b && vite build && electron-builder",
    "lint": "eslint .",
    "preview": "vite preview",
    "selftest": "electron . --selftest",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "better-sqlite3": "^12.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^2.12.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@electron/rebuild": "^3.7.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.1.2",
    "electron": "^35.2.1",
    "electron-builder": "^26.0.12",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "wait-on": "^8.0.1"
    
  },
  "build": {
    "appId": "com.fcpricemaster.app",
    "productName": "FCPriceMaster",
    "files": ["dist/**/*", "electron/**/*"],
    "win": {
      "target": "nsis"
    }
    
  },
  
  "pnpm": {
  "onlyBuiltDependencies": [
    "better-sqlite3",
    "electron",
    "electron-winstaller"
  ]
}
  
}
