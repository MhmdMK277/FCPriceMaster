# FCPriceMaster environment variables — copy to .env and fill in values
# NEVER commit .env to git

# Anthropic API key — required for Ask feature and autonomous recommendations
ANTHROPIC_API_KEY=sk-ant-your-key-here

# NVIDIA NIM API key — free tier, enables multi-model Ask comparison
# Get your key at https://build.nvidia.com
NVIDIA_API_KEY=nvapi-your-key-here

# Discord bot token — required for Discord signal ingestion
DISCORD_BOT_TOKEN=your-discord-bot-token-here

# Reddit OAuth2 credentials — required for Reddit signal ingestion
# Create a script app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USERNAME=your-reddit-username
